<Window x:Class="WpfApp1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модуль Технолога" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель навигации -->
        <Border Grid.Row="0" Background="#2196F3" Padding="10">
            <Grid>
                <!-- Левое меню -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="btnProducts" Content="📦 Продукция" Click="Products_Click" 
                            Background="Transparent" Foreground="White" Margin="0,0,10,0" Height="35"/>
                    <Button x:Name="btnRecipes" Content="📋 Рецептуры" Click="Recipes_Click" 
                            Background="Transparent" Foreground="White" Margin="0,0,10,0" Height="35"/>
                    <Button x:Name="btnTechMaps" Content="🗺️ Техкарты" Click="TechMaps_Click" 
                            Background="Transparent" Foreground="White" Margin="0,0,10,0" Height="35"/>
                    <Button x:Name="btnMaterials" Content="📦 Сырье" Click="Materials_Click" 
                            Background="Transparent" Foreground="White" Margin="0,0,10,0" Height="35"/>
                    <Button x:Name="btnOrders" Content="📑 Заказы" Click="Orders_Click" 
                            Background="Transparent" Foreground="White" Margin="0,0,10,0" Height="35"/>
                    <Button x:Name="btnMonitoring" Content="📊 Мониторинг" Click="Monitoring_Click" 
                            Background="Transparent" Foreground="White" Margin="0,0,10,0" Height="35"/>
                    <Button x:Name="btnReports" Content="📈 Отчеты" Click="Reports_Click" 
                            Background="Transparent" Foreground="White" Margin="0,0,10,0" Height="35"/>
                </StackPanel>

                <!-- Правая часть - пользователь -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#1976D2" CornerRadius="15" Padding="10,5" Margin="0,0,15,0">
                        <TextBlock x:Name="tbUserFullName" Text="{Binding UserFullName}" 
                                   Foreground="White" FontSize="13"/>
                    </Border>
                    <Button x:Name="btnLogout" Content="🚪 Выход" Click="Logout_Click" 
                            Background="#F44336" Foreground="White" Width="80" Height="35"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Область контента -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="15">
            <ContentControl x:Name="contentControl"/>
        </Border>

        <!-- Статус бар -->
        <Border Grid.Row="2" Background="#E0E0E0" Padding="8">
            <TextBlock x:Name="statusBar" Text="Готов к работе" FontSize="11" Foreground="#424242"/>
        </Border>
    </Grid>
</Window>