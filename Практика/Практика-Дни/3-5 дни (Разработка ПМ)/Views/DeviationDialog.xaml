<Window x:Class="WpfApp1.Views.DeviationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация отклонения" Height="550" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Цвета -->
        <SolidColorBrush x:Key="DangerBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="DangerDarkBrush" Color="#D32F2F"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="GrayBrush" Color="#9E9E9E"/>
        <SolidColorBrush x:Key="GrayDarkBrush" Color="#757575"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <!-- Тени -->
        <DropShadowEffect x:Key="WindowShadow" BlurRadius="25" Opacity="0.3" ShadowDepth="0"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="6" Opacity="0.15" ShadowDepth="1"/>

        <!-- Стили -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource WarningBrush}" CornerRadius="12,12,0,0" Height="65">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="25,0">
                        <TextBlock Text="⚠️" FontSize="28" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Регистрация отклонения" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Заполните информацию о возникшем отклонении" 
                                       FontSize="12" Foreground="White" Opacity="0.8" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопка закрытия -->
                    <Button x:Name="btnClose" Click="Cancel_Click" 
                            Width="34" Height="34" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"
                            Cursor="Hand" Background="Transparent" BorderThickness="0">
                        <TextBlock Text="✕" FontSize="20" Foreground="White" Opacity="0.7"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Иконка -->
            <Border Grid.Row="1" Width="70" Height="70" CornerRadius="35" 
                    Background="#FFF3E0" Margin="0,-35,0,0" HorizontalAlignment="Center"
                    Effect="{StaticResource ButtonShadow}">
                <TextBlock Text="⚠️" FontSize="36" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,45,30,20">
                <StackPanel>
                    <!-- Тип отклонения -->
                    <TextBlock Text="Тип отклонения" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="cmbDeviationType" SelectedIndex="0">
                        <ComboBoxItem Content="🌡️ Температура"/>
                        <ComboBoxItem Content="📊 Давление"/>
                        <ComboBoxItem Content="⏱️ Время"/>
                        <ComboBoxItem Content="🔬 Качество сырья"/>
                        <ComboBoxItem Content="⚙️ Оборудование"/>
                        <ComboBoxItem Content="👤 Персонал"/>
                        <ComboBoxItem Content="📋 Прочее"/>
                    </ComboBox>

                    <!-- Важность -->
                    <TextBlock Text="Важность отклонения" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="cmbSeverity" SelectedIndex="1">
                        <ComboBoxItem Content="🟢 Низкая">
                            <ComboBoxItem.Foreground>
                                <SolidColorBrush Color="#4CAF50"/>
                            </ComboBoxItem.Foreground>
                        </ComboBoxItem>
                        <ComboBoxItem Content="🟡 Средняя">
                            <ComboBoxItem.Foreground>
                                <SolidColorBrush Color="#FF9800"/>
                            </ComboBoxItem.Foreground>
                        </ComboBoxItem>
                        <ComboBoxItem Content="🟠 Высокая">
                            <ComboBoxItem.Foreground>
                                <SolidColorBrush Color="#F44336"/>
                            </ComboBoxItem.Foreground>
                        </ComboBoxItem>
                        <ComboBoxItem Content="🔴 Критическая">
                            <ComboBoxItem.Foreground>
                                <SolidColorBrush Color="#D32F2F"/>
                            </ComboBoxItem.Foreground>
                        </ComboBoxItem>
                    </ComboBox>

                    <!-- Описание -->
                    <TextBlock Text="Описание отклонения" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtDescription" Height="130" TextWrapping="Wrap" 
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <!-- Подсказка -->
                    <TextBlock Text="* Детально опишите характер и причины отклонения" 
                               FontSize="11" Foreground="#9E9E9E" Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,12,12" Padding="20,15" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancel" Content="Отмена" Click="Cancel_Click" 
                            Width="100" Height="38" Margin="0,0,10,0" Cursor="Hand"
                            Background="#F5F5F5" Foreground="#616161" FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Style="{StaticResource ActionButton}"/>

                    <Button x:Name="btnRegister" Content="Зарегистрировать" Click="Register_Click" 
                            Width="150" Height="38" Cursor="Hand"
                            Background="{StaticResource WarningBrush}" Foreground="White" 
                            FontSize="13" FontWeight="SemiBold" BorderThickness="0" Style="{StaticResource ActionButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>