<Window x:Class="WpfApp1.Views.RecipeComponentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Компонент рецептуры" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2196F3"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="25" Opacity="0.3" ShadowDepth="0"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="6" Opacity="0.15" ShadowDepth="1"/>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,5,0,18"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,5,0,18"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Height="65">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="25,0">
                        <TextBlock Text="🧪" FontSize="28" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Компонент рецептуры" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Добавление/редактирование компонента" 
                                       FontSize="12" Foreground="White" Opacity="0.8" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="btnClose" Click="Cancel_Click" 
                            Width="34" Height="34" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"
                            Cursor="Hand" Background="Transparent" BorderThickness="0">
                        <TextBlock Text="✕" FontSize="20" Foreground="White" Opacity="0.7"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Иконка -->
            <Border Grid.Row="1" Width="70" Height="70" CornerRadius="35" 
                    Background="#E3F2FD" Margin="0,-35,0,0" HorizontalAlignment="Center"
                    Effect="{StaticResource ButtonShadow}">
                <TextBlock Text="🧪" FontSize="36" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,45,30,20">
                <StackPanel>
                    <TextBlock Text="Сырье / Материал" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="cmbMaterial" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <TextBlock Text="Количество" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtQuantity" Grid.Column="0"/>
                        <ComboBox x:Name="cmbUnit" Grid.Column="1" Width="100" Margin="12,0,0,0" SelectedIndex="0">
                            <ComboBoxItem Content="кг"/>
                            <ComboBoxItem Content="л"/>
                            <ComboBoxItem Content="г"/>
                            <ComboBoxItem Content="мл"/>
                            <ComboBoxItem Content="шт"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="Допуск (%)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtTolerance" Text="5"/>

                    <TextBlock Text="Порядок загрузки" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="cmbLoadOrder" SelectedIndex="0">
                        <ComboBoxItem Content="1️⃣ Первый"/>
                        <ComboBoxItem Content="2️⃣ Второй"/>
                        <ComboBoxItem Content="3️⃣ Третий"/>
                        <ComboBoxItem Content="4️⃣ Четвертый"/>
                        <ComboBoxItem Content="5️⃣ Пятый"/>
                        <ComboBoxItem Content="6️⃣ Шестой"/>
                        <ComboBoxItem Content="7️⃣ Седьмой"/>
                        <ComboBoxItem Content="8️⃣ Восьмой"/>
                        <ComboBoxItem Content="9️⃣ Девятый"/>
                        <ComboBoxItem Content="🔟 Десятый"/>
                    </ComboBox>

                    <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Информация" FontWeight="SemiBold" Foreground="#424242"/>
                            </StackPanel>
                            <TextBlock Text="• Допуск указывается в процентах от указанного количества" 
                                       FontSize="12" Foreground="#757575" Margin="26,0,0,5"/>
                            <TextBlock Text="• Порядок загрузки определяет последовательность добавления" 
                                       FontSize="12" Foreground="#757575" Margin="26,0,0,5"/>
                            <TextBlock Text="• Компоненты с меньшим порядком загружаются первыми" 
                                       FontSize="12" Foreground="#757575" Margin="26,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,12,12" Padding="20,15" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancel" Content="Отмена" Click="Cancel_Click" 
                            Width="100" Height="38" Margin="0,0,10,0" Cursor="Hand"
                            Background="#F5F5F5" Foreground="#616161" FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Style="{StaticResource ActionButton}"/>

                    <Button x:Name="btnOk" Content="Сохранить" Click="Ok_Click" 
                            Width="110" Height="38" Cursor="Hand"
                            Background="{StaticResource SuccessBrush}" Foreground="White" 
                            FontSize="13" FontWeight="SemiBold" BorderThickness="0" Style="{StaticResource ActionButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>