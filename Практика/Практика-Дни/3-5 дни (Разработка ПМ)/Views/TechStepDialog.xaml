<Window x:Class="WpfApp1.Views.TechStepDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Технологический шаг" Height="697" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Технологический шаг" FontSize="16" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500">
            <StackPanel>
                <TextBlock Text="Название шага:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Тип шага:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbStepType" Height="35" Margin="0,0,0,15" SelectedIndex="0">
                    <ComboBoxItem Content="Смешивание"/>
                    <ComboBoxItem Content="Нагрев"/>
                    <ComboBoxItem Content="Охлаждение"/>
                    <ComboBoxItem Content="Дозирование"/>
                    <ComboBoxItem Content="Контроль"/>
                    <ComboBoxItem Content="Фасовка"/>
                    <ComboBoxItem Content="Упаковка"/>
                </ComboBox>

                <TextBlock Text="Инструкции:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtInstructions" Height="80" TextWrapping="Wrap" 
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>

                <TextBlock Text="Контролируемый параметр:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtParamName" Height="35" Margin="0,0,0,15" Text="Температура"/>

                <TextBlock Text="Целевое значение:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtParamTarget" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Минимальное значение:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtParamMin" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Максимальное значение:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtParamMax" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Единица измерения:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbParamUnit" Height="35" Margin="0,0,0,15" SelectedIndex="0">
                    <ComboBoxItem Content="°C"/>
                    <ComboBoxItem Content="°F"/>
                    <ComboBoxItem Content="bar"/>
                    <ComboBoxItem Content="kPa"/>
                    <ComboBoxItem Content="%"/>
                    <ComboBoxItem Content="л"/>
                    <ComboBoxItem Content="кг"/>
                </ComboBox>

                <TextBlock Text="Длительность (минут):" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDurationMin" Height="35" Margin="0,0,0,15"/>

                <CheckBox x:Name="chkIsMandatory" Content="Обязательный шаг" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
            <Button Content="OK" Width="80" Height="35" Click="Ok_Click" Background="#27AE60" Foreground="White" Margin="5"/>
            <Button Content="Отмена" Width="80" Height="35" Click="Cancel_Click" Background="#95A5A6" Foreground="White" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>