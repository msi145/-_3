<Window x:Class="WpfApp1.Views.RecipeViewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр рецептуры" Height="500" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2196F3"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1976D2"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="25" Opacity="0.3" ShadowDepth="0"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>

        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="42"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Height="55">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="📖" FontSize="22"/>
                        <TextBlock Text="Просмотр рецептуры" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="10,0,0,0"/>
                    </StackPanel>
                    <Button x:Name="btnClose" Click="Close_Click" 
                            Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0"
                            Cursor="Hand" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="16" Opacity="0.7">✕</Button>
                </Grid>
            </Border>

            <!-- Содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
                <StackPanel>
                    <!-- Информационная карточка -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,10">
                                <TextBlock Text="ID рецептуры" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock x:Name="tbId" Style="{StaticResource InfoValueStyle}" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,10">
                                <TextBlock Text="Продукт" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock x:Name="tbProduct" Style="{StaticResource InfoValueStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,10">
                                <TextBlock Text="Версия" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock x:Name="tbVersion" Style="{StaticResource InfoValueStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,10">
                                <TextBlock Text="Статус" Style="{StaticResource InfoLabelStyle}"/>
                                <Border x:Name="statusBorder" CornerRadius="12" Padding="8,3" Background="#4CAF50" HorizontalAlignment="Left">
                                    <TextBlock x:Name="tbStatus" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="4" Margin="15,0,0,0">
                                <TextBlock Text="Описание" Style="{StaticResource InfoLabelStyle}" Margin="0,0,0,5"/>
                                <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <TextBlock x:Name="tbDescription" TextWrapping="Wrap" FontSize="13" Foreground="#424242" MinHeight="70"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Компоненты -->
                    <Border Background="White" CornerRadius="10" Padding="15" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Компоненты рецептуры" FontSize="15" FontWeight="SemiBold" Foreground="#212121" Margin="0,0,0,12"/>
                            <DataGrid x:Name="dgComponents" AutoGenerateColumns="False" Height="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="*"/>
                                    <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                                    <DataGridTextColumn Header="Ед.изм" Binding="{Binding Unit}" Width="80"/>
                                    <DataGridTextColumn Header="Допуск %" Binding="{Binding TolerancePct}" Width="80"/>
                                    <DataGridTextColumn Header="Порядок" Binding="{Binding LoadOrder}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock x:Name="tbComponentsCount" Text="Всего компонентов: 0" FontSize="11" Foreground="#757575" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,12,12" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCloseWindow" Click="Close_Click" 
                            Width="100" Height="35" Cursor="Hand"
                            Background="{StaticResource PrimaryBrush}" Foreground="White" 
                            FontSize="13" FontWeight="SemiBold" BorderThickness="0">Закрыть</Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>