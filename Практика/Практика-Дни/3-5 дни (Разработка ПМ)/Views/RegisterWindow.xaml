<Window x:Class="WpfApp1.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="650" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="SuccessDarkBrush" Color="#388E3C"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <DropShadowEffect x:Key="WindowShadow" BlurRadius="25" Opacity="0.3" ShadowDepth="0"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="6" Opacity="0.15" ShadowDepth="1"/>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="#2196F3" Opacity="0.15"/>
        <Rectangle Fill="White" Opacity="0.95"/>

        <Border Background="White" CornerRadius="16" Effect="{StaticResource WindowShadow}" 
                Width="460" Height="620" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="25,20,25,0">
                    <StackPanel>
                        <!-- Заголовок -->
                        <StackPanel Margin="0,0,0,15" HorizontalAlignment="Center">
                            <Border Width="60" Height="60" CornerRadius="30" Background="#E3F2FD" 
                                    HorizontalAlignment="Center" Effect="{StaticResource ButtonShadow}">
                                <TextBlock Text="📝" FontSize="32" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Регистрация" FontSize="20" FontWeight="Bold" 
                                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,10,0,3"/>
                            <TextBlock Text="Создайте учетную запись" FontSize="11" 
                                       Foreground="#757575" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- ФИО -->
                        <TextBlock Text="ФИО" FontSize="12" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtFullName" Height="38" Margin="0,3,0,12" Padding="12,8" 
                                 BorderBrush="#E0E0E0" BorderThickness="1" FontSize="13"/>

                        <!-- Логин -->
                        <TextBlock Text="Логин" FontSize="12" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtUsername" Height="38" Margin="0,3,0,12" Padding="12,8" 
                                 BorderBrush="#E0E0E0" BorderThickness="1" FontSize="13"/>

                        <!-- Email -->
                        <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtEmail" Height="38" Margin="0,3,0,12" Padding="12,8" 
                                 BorderBrush="#E0E0E0" BorderThickness="1" FontSize="13"/>

                        <!-- Пароль -->
                        <TextBlock Text="Пароль (мин. 6 символов)" FontSize="12" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,3"/>
                        <PasswordBox x:Name="txtPassword" Height="38" Margin="0,3,0,12" Padding="12,8" 
                                     BorderBrush="#E0E0E0" BorderThickness="1" FontSize="13"/>

                        <!-- Капча -->
                        <TextBlock Text="Код подтверждения" FontSize="12" FontWeight="SemiBold" Foreground="#424242" Margin="0,5,0,3"/>
                        <Grid Margin="0,3,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtCaptcha" Grid.Column="0" Height="38" Padding="12,8" 
                                     BorderBrush="#E0E0E0" BorderThickness="1" FontSize="14" 
                                     FontWeight="Bold" TextAlignment="Center" MaxLength="4"/>
                            <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="8" 
                                    BorderBrush="#E0E0E0" BorderThickness="1" Background="#F5F5F5" Width="130" Height="38">
                                <Image x:Name="imgCaptcha" Stretch="Fill" Margin="5"/>
                            </Border>
                            <Button x:Name="btnRefreshCaptcha" Grid.Column="1" Width="40" Height="38" 
                                    Margin="150,0,0,0" Click="RefreshCaptcha_Click" 
                                    Background="#607D8B" Foreground="White" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <TextBlock Text="🔄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Ошибка -->
                        <TextBlock x:Name="lblError" Foreground="#F44336" FontSize="11" 
                                   HorizontalAlignment="Center" Margin="0,10,0,10"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопки -->
                <Border Grid.Row="1" Background="White" CornerRadius="0,0,16,16" Padding="25,15,25,20"
                        BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnRegister" Content="Зарегистрироваться" Click="Register_Click" 
                                Width="160" Height="40" Cursor="Hand" Background="#4CAF50" Foreground="White" 
                                FontSize="13" FontWeight="SemiBold" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✓" FontSize="14" Margin="0,0,8,0"/>
                                            <ContentPresenter/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnCancel" Content="Отмена" Click="Cancel_Click" 
                                Width="90" Height="40" Margin="12,0,0,0" Cursor="Hand"
                                Background="#F5F5F5" Foreground="#616161" FontSize="13" FontWeight="SemiBold"
                                BorderThickness="1" BorderBrush="#E0E0E0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>