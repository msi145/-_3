<Window x:Class="WpfApp1.Views.TechMapViewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр технологической карты" Height="550" Width="800"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Просмотр технологической карты" FontSize="18" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Информация -->
        <GroupBox Header="Информация о техкарте" Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ID:" VerticalAlignment="Center"/>
                <TextBlock x:Name="tbId" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Text="Название:" Grid.Row="1" VerticalAlignment="Center"/>
                <TextBlock x:Name="tbName" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Text="Рецептура:" Grid.Row="2" VerticalAlignment="Center"/>
                <TextBlock x:Name="tbRecipe" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Text="Версия:" Grid.Row="3" VerticalAlignment="Center"/>
                <TextBlock x:Name="tbVersion" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Text="Статус:" Grid.Column="2" Grid.Row="1" VerticalAlignment="Center"/>
                <TextBlock x:Name="tbStatus" Grid.Column="3" Grid.Row="1" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- Шаги -->
        <GroupBox Header="Технологические шаги" Grid.Row="2">
            <DataGrid x:Name="dgSteps" AutoGenerateColumns="False" IsReadOnly="True" Margin="5"
                      AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding StepNumber}" Width="60"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding StepType}" Width="100"/>
                    <DataGridTextColumn Header="Параметр" Binding="{Binding ParamName}" Width="100"/>
                    <DataGridTextColumn Header="Целевое" Binding="{Binding ParamTarget}" Width="80"/>
                    <DataGridTextColumn Header="Мин" Binding="{Binding ParamMin}" Width="60"/>
                    <DataGridTextColumn Header="Макс" Binding="{Binding ParamMax}" Width="60"/>
                    <DataGridTextColumn Header="Длительность" Binding="{Binding DurationMin}" Width="100"/>
                    <DataGridTextColumn Header="Инструкции" Binding="{Binding Instructions}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Button Grid.Row="3" Content="Закрыть" Width="100" Height="35" 
                Click="Close_Click" Background="#3498DB" Foreground="White" HorizontalAlignment="Right" Margin="0,15"/>
    </Grid>
</Window>