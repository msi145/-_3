<Window x:Class="WpfApp1.Views.StepCompleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершение шага" 
        Height="580" Width="520"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2196F3"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="InfoBgBrush" Color="#E3F2FD"/>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="25" Opacity="0.3" ShadowDepth="0"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="6" Opacity="0.15" ShadowDepth="1"/>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="ValueStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource SuccessBrush}" CornerRadius="12,12,0,0" Height="65">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="25,0">
                        <TextBlock Text="✅" FontSize="28" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Завершение технологического шага" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Введите фактические параметры выполнения" 
                                       FontSize="12" Foreground="White" Opacity="0.8" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="btnClose" Click="Cancel_Click" 
                            Width="34" Height="34" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"
                            Cursor="Hand" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="20" Opacity="0.7">✕</Button>
                </Grid>
            </Border>

            <!-- Иконка -->
            <Border Grid.Row="1" Width="70" Height="70" CornerRadius="35" 
                    Background="#E8F5E9" Margin="0,-35,0,0" HorizontalAlignment="Center"
                    Effect="{StaticResource ButtonShadow}">
                <TextBlock Text="⚙️" FontSize="36" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,45,30,20">
                <StackPanel>
                    <!-- Информация о шаге -->
                    <Border Background="{StaticResource InfoBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="🔧 Информация о шаге" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,8"/>
                            <TextBlock Text="Шаг:" FontSize="12" FontWeight="SemiBold" Foreground="#616161"/>
                            <TextBlock x:Name="tbStepName" FontSize="15" FontWeight="SemiBold" Foreground="#1976D2"/>
                        </StackPanel>
                    </Border>

                    <!-- Фактическое значение -->
                    <TextBlock Text="📊 Фактическое значение параметра" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtActualValue"/>

                    <!-- Длительность -->
                    <TextBlock Text="⏱️ Фактическая длительность (минут)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtActualDuration"/>

                    <!-- Комментарий -->
                    <TextBlock Text="💬 Комментарий" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtComment" Height="100" TextWrapping="Wrap" 
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="* Оставьте комментарий при наличии отклонений" 
                               FontSize="11" Foreground="#9E9E9E" Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,12,12" Padding="20,15" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancel" Content="Отмена" Click="Cancel_Click" 
                            Width="100" Height="38" Margin="0,0,10,0" Cursor="Hand"
                            Background="#F5F5F5" Foreground="#616161" FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Style="{StaticResource ActionButton}"/>

                    <Button x:Name="btnComplete" Content="Завершить шаг" Click="Complete_Click" 
                            Width="130" Height="38" Cursor="Hand"
                            Background="{StaticResource SuccessBrush}" Foreground="White" 
                            FontSize="13" FontWeight="SemiBold" BorderThickness="0" Style="{StaticResource ActionButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>