<UserControl x:Class="WpfApp1.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📦" FontSize="28"/>
                    <TextBlock Text="Справочник продукции" FontSize="22" FontWeight="Bold" 
                               Foreground="#2C3E50" Margin="12,0,0,0"/>
                </StackPanel>
                <TextBlock Text="Управление номенклатурой выпускаемой продукции" 
                           FontSize="13" Foreground="#757575" Margin="40,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Таблица -->
        <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9" Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Тип продукции" Binding="{Binding ProductType}" Width="150"/>
                <DataGridTextColumn Header="Форма выпуска" Binding="{Binding ReleaseForm}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTemplateColumn Header="Действия" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️" Width="30" Click="EditProduct_Click" Tag="{Binding}"/>
                                <Button Content="🗑️" Width="30" Click="DeleteProduct_Click" Tag="{Binding}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма добавления -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Добавить продукцию:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBox x:Name="txtName" Grid.Column="1" Margin="0,0,10,0" Height="35"/>
                <ComboBox x:Name="cmbProductType" Grid.Column="2" Margin="0,0,10,0" Height="35">
                    <ComboBoxItem Content="Активное вещество"/>
                    <ComboBoxItem Content="Вспомогательное вещество"/>
                    <ComboBoxItem Content="Готовая форма"/>
                </ComboBox>
                <ComboBox x:Name="cmbReleaseForm" Grid.Column="3" Margin="0,0,10,0" Height="35">
                    <ComboBoxItem Content="Концентрат"/>
                    <ComboBoxItem Content="Эмульсия"/>
                    <ComboBoxItem Content="Порошок"/>
                    <ComboBoxItem Content="Гранулы"/>
                </ComboBox>
                <Button Grid.Column="4" Content="➕ Добавить" Width="100" Height="35" 
                        Click="AddProduct_Click" Background="#4CAF50" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>