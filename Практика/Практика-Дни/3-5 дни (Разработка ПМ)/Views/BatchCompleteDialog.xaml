<Window x:Class="WpfApp1.Views.BatchCompleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершение партии" Height="300" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="#4CAF50" CornerRadius="12,12,0,0">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="28" Height="28" Fill="#3d8b40"/>
                        <TextBlock Text="✓" FontSize="14" Foreground="White"
                                   Margin="-21,0,0,0" VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="Завершение партии"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="btnClose" Click="Cancel_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="White" FontSize="16" Opacity="0.75"
                            Content="✕"/>
                </Grid>
            </Border>

            <!-- Форма -->
            <StackPanel Grid.Row="1" Margin="28,20,28,16" VerticalAlignment="Center">
                <TextBlock Text="Фактическое количество произведённой продукции"
                           FontSize="13" Foreground="#757575"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="8" Background="#FAFAFA" Height="50">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtActualQty" Grid.Column="0"
                                 FontSize="22" FontWeight="SemiBold"
                                 Foreground="#4CAF50" TextAlignment="Right"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="txtActualQty_PreviewTextInput"/>
                        <TextBlock Grid.Column="1" Text="кг"
                                   FontSize="15" Foreground="#9E9E9E"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="txtHint" Text="* Введите положительное число"
                           FontSize="11" Foreground="#BDBDBD"
                           Margin="0,6,0,0" TextAlignment="Center"/>
            </StackPanel>

            <!-- Кнопки -->
            <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="0,0,12,12"
                    BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="20,0">
                    <Button x:Name="btnCancel" Content="Отмена" Click="Cancel_Click"
                            Width="90" Height="36" Cursor="Hand"
                            FontSize="13" Background="#EEEEEE"
                            Foreground="#616161" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnComplete" Content="Завершить" Click="Complete_Click"
                            Width="110" Height="36" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#4CAF50" Foreground="White" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>